# Aurralis Mobile App — Environment Variables
# Copy this file to .env and fill in the values.
# EXPO_PUBLIC_ prefix makes variables available in the app bundle at build time.

# Backend API base URL (no trailing slash)
# Development (simulator):  leave empty to use the auto-detected localhost fallback
# Development (device):     http://192.168.1.x:3000  (your machine's LAN IP)
# Production:               https://your-domain.com
EXPO_PUBLIC_API_URL=
