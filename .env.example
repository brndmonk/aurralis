# Aurralis - Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/aurralis"

# ─── Auth (NextAuth / Auth.js) ─────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
AUTH_SECRET=""

# Admin credentials for the web dashboard login
ADMIN_EMAIL="admin@yourdomain.com"
# Generate bcrypt hash: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=""

# ─── Email (Resend) ────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
# ⚠ Rotate this key immediately if it was ever committed to git
RESEND_API_KEY=""

# ─── Object Storage (MinIO / AWS S3 / Cloudflare R2) ──────────────────────
MINIO_ENDPOINT="s3.amazonaws.com"
MINIO_PORT="443"
MINIO_USE_SSL="true"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_BUCKET="aurralis"

# ─── Payment Gateways (enable in Settings page) ────────────────────────────
STRIPE_SECRET_KEY=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ─── Twilio SMS (enable in Settings page) ─────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
